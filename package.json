{
  "name": "pura",
  "version": "1.0.0",
  "private": true,
  "description": "PURA Property Management System",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md,yml,yaml}\"",
    "lint:fix": "turbo lint",
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api dev",
    "db:push": "pnpm --filter database db:push",
    "db:generate": "pnpm --filter database db:generate",
    "sonar": "pnpm test:coverage && npx dotenv-cli -- npx sonarqube-scanner",
    "prepare": "husky || true",
    "test": "turbo test",
    "test:coverage": "turbo test:cov",
    "test:e2e": "pnpm --filter web test:e2e"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2.8.17"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "overrides": {
      "lodash": "4.17.23",
      "next": ">=16.1.7",
      "@isaacs/brace-expansion": ">=5.0.1",
      "minimatch": ">=10.2.3",
      "rollup": ">=4.59.0",
      "multer": ">=2.1.1",
      "undici": ">=7.24.0",
      "serialize-javascript": ">=7.0.3",
      "flatted": ">=3.4.0",
      "file-type": ">=21.3.2",
      "qs": ">=6.14.2",
      "ajv": ">=8.18.0",
      "eslint>ajv": "6.14.0",
      "@eslint/eslintrc>ajv": "6.14.0"
    }
  }
}
