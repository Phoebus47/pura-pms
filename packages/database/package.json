{
  "name": "@pura/database",
  "version": "1.0.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "postinstall": "prisma generate",
    "build": "prisma generate && tsc -p tsconfig.build.json",
    "dev": "tsc --watch",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.mts",
    "db:seed-financial": "tsx prisma/seed-financial.ts",
    "db:verify-seed": "tsx prisma/verify-seed.mts",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:perf": "vitest run performance.test.ts",
    "test:unit": "vitest run --exclude performance.test.ts",
    "test:isolated": "vitest run --pool=forks"
  },
  "dependencies": {
    "@prisma/client": "^7.6.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "dotenv": "^17.3.1",
    "prisma": "^7.6.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^6.0.2",
    "unplugin-swc": "^1.5.9",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2"
  }
}
