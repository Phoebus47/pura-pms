generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== USERS & AUTH ====================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  firstName     String
  lastName      String
  roleId        String
  role          Role      @relation(fields: [roleId], references: [id])
  isActive      Boolean   @default(true)
  shifts        Shift[]
  auditLogs     AuditLog[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  permissions String[]
  users       User[]
}

// ==================== PROPERTY ====================

model Property {
  id          String     @id @default(cuid())
  name        String
  address     String?
  phone       String?
  email       String?
  taxId       String?
  currency    String     @default("THB")
  timezone    String     @default("Asia/Bangkok")
  roomTypes   RoomType[]
  rooms       Room[]
  rates       Rate[]
  createdAt   DateTime   @default(now())
}

model RoomType {
  id          String   @id @default(cuid())
  name        String
  code        String
  description String?
  baseRate    Decimal  @db.Decimal(10, 2)
  maxAdults   Int      @default(2)
  maxChildren Int      @default(1)
  amenities   String[]
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id])
  rooms       Room[]
  rates       Rate[]
}

model Room {
  id           String             @id @default(cuid())
  number       String
  floor        Int?
  status       RoomStatus         @default(VACANT_CLEAN)
  roomTypeId   String
  roomType     RoomType           @relation(fields: [roomTypeId], references: [id])
  propertyId   String
  property     Property           @relation(fields: [propertyId], references: [id])
  reservations Reservation[]
  housekeeping HousekeepingTask[]
  @@unique([propertyId, number])
}

// ==================== GUESTS ====================

model Guest {
  id           String        @id @default(cuid())
  firstName    String
  lastName     String
  email        String?
  phone        String?
  idType       String?
  idNumber     String?
  nationality  String?
  dateOfBirth  DateTime?
  address      String?
  vipLevel     Int           @default(0)
  isBlacklist  Boolean       @default(false)
  notes        String?
  preferences  Json?
  totalStays   Int           @default(0)
  totalRevenue Decimal       @default(0) @db.Decimal(12, 2)
  reservations Reservation[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

// ==================== RESERVATIONS ====================

model Reservation {
  id             String            @id @default(cuid())
  confirmNumber  String            @unique
  checkIn        DateTime
  checkOut       DateTime
  nights         Int
  adults         Int               @default(1)
  children       Int               @default(0)
  status         ReservationStatus @default(CONFIRMED)
  source         String?
  rateCode       String?
  roomRate       Decimal           @db.Decimal(10, 2)
  totalAmount    Decimal           @db.Decimal(12, 2)
  paidAmount     Decimal           @default(0) @db.Decimal(12, 2)
  notes          String?
  specialRequest String?
  roomId         String
  room           Room              @relation(fields: [roomId], references: [id])
  guestId        String
  guest          Guest             @relation(fields: [guestId], references: [id])
  folios         Folio[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  checkedInAt    DateTime?
  checkedOutAt   DateTime?
  @@index([checkIn, checkOut])
  @@index([status])
}

// ==================== BILLING ====================

model Folio {
  id            String        @id @default(cuid())
  folioNumber   String        @unique
  reservationId String
  reservation   Reservation   @relation(fields: [reservationId], references: [id])
  type          FolioType     @default(GUEST)
  balance       Decimal       @default(0) @db.Decimal(12, 2)
  isClosed      Boolean       @default(false)
  transactions  Transaction[]
  createdAt     DateTime      @default(now())
}

model Transaction {
  id          String          @id @default(cuid())
  folioId     String
  folio       Folio           @relation(fields: [folioId], references: [id])
  type        TransactionType
  category    String
  description String
  amount      Decimal         @db.Decimal(12, 2)
  tax         Decimal         @default(0) @db.Decimal(10, 2)
  shiftId     String?
  shift       Shift?          @relation(fields: [shiftId], references: [id])
  postedBy    String
  postedAt    DateTime        @default(now())
  isVoid      Boolean         @default(false)
  voidReason  String?
  voidedAt    DateTime?
}

model Payment {
  id         String        @id @default(cuid())
  folioId    String
  amount     Decimal       @db.Decimal(12, 2)
  method     PaymentMethod
  reference  String?
  cardLast4  String?
  shiftId    String?
  receivedBy String
  receivedAt DateTime      @default(now())
}

// ==================== SHIFT MANAGEMENT ====================

model Shift {
  id           String        @id @default(cuid())
  shiftNumber  String        @unique
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  startTime    DateTime
  endTime      DateTime?
  openingCash  Decimal       @db.Decimal(12, 2)
  closingCash  Decimal?      @db.Decimal(12, 2)
  cashVariance Decimal?      @db.Decimal(12, 2)
  status       ShiftStatus   @default(OPEN)
  transactions Transaction[]
  notes        String?
}

// ==================== NIGHT AUDIT ====================

model NightAudit {
  id            String          @id @default(cuid())
  businessDate  DateTime        @db.Date
  status        AuditStatus     @default(PENDING)
  startedAt     DateTime?
  completedAt   DateTime?
  performedBy   String?
  roomsPosted   Int             @default(0)
  revenuePosted Decimal         @default(0) @db.Decimal(12, 2)
  discrepancies Json?
  notes         String?
  reports       ReportArchive[]
  errors        AuditError[]
  @@unique([businessDate])
}

model AuditError {
  id           String     @id @default(cuid())
  nightAuditId String
  nightAudit   NightAudit @relation(fields: [nightAuditId], references: [id])
  errorType    String
  description  String
  resolved     Boolean    @default(false)
  resolvedBy   String?
  resolvedAt   DateTime?
}

// ==================== REPORT ARCHIVE ====================

model ReportArchive {
  id           String      @id @default(cuid())
  reportType   String
  reportName   String
  businessDate DateTime    @db.Date
  parameters   Json?
  data         Json
  summary      Json?
  pdfPath      String?
  excelPath    String?
  nightAuditId String?
  nightAudit   NightAudit? @relation(fields: [nightAuditId], references: [id])
  generatedBy  String
  generatedAt  DateTime    @default(now())
  @@index([reportType, businessDate])
  @@index([businessDate])
}

// ==================== FINANCIAL ====================

model GLAccount {
  id       String        @id @default(cuid())
  code     String        @unique
  name     String
  type     AccountType
  parentCode String?
  isActive Boolean       @default(true)
  balance  Decimal       @default(0) @db.Decimal(14, 2)
  entries  JournalLine[]
}

model JournalEntry {
  id          String        @id @default(cuid())
  entryNumber String        @unique
  entryDate   DateTime      @db.Date
  reference   String?
  description String
  source      String?
  lines       JournalLine[]
  isPosted    Boolean       @default(false)
  postedBy    String?
  postedAt    DateTime?
  createdAt   DateTime      @default(now())
}

model JournalLine {
  id          String       @id @default(cuid())
  journalId   String
  journal     JournalEntry @relation(fields: [journalId], references: [id])
  accountId   String
  account     GLAccount    @relation(fields: [accountId], references: [id])
  debit       Decimal      @default(0) @db.Decimal(14, 2)
  credit      Decimal      @default(0) @db.Decimal(14, 2)
  description String?
}

model ARAccount {
  id             String    @id @default(cuid())
  accountNumber  String    @unique
  companyName    String
  contactPerson  String?
  email          String?
  phone          String?
  address        String?
  creditLimit    Decimal   @db.Decimal(14, 2)
  currentBalance Decimal   @default(0) @db.Decimal(14, 2)
  paymentTerms   Int       @default(30)
  isActive       Boolean   @default(true)
  invoices       Invoice[]
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  arAccountId   String
  arAccount     ARAccount     @relation(fields: [arAccountId], references: [id])
  invoiceDate   DateTime      @db.Date
  dueDate       DateTime      @db.Date
  amount        Decimal       @db.Decimal(14, 2)
  paidAmount    Decimal       @default(0) @db.Decimal(14, 2)
  status        InvoiceStatus @default(OPEN)
  createdAt     DateTime      @default(now())
}

// ==================== HOUSEKEEPING ====================

model HousekeepingTask {
  id          String     @id @default(cuid())
  roomId      String
  room        Room       @relation(fields: [roomId], references: [id])
  taskType    String
  priority    Int        @default(1)
  assignedTo  String?
  status      TaskStatus @default(PENDING)
  notes       String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime   @default(now())
}

// ==================== RATES ====================

model Rate {
  id         String   @id @default(cuid())
  code       String
  name       String
  roomTypeId String
  roomType   RoomType @relation(fields: [roomTypeId], references: [id])
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])
  amount     Decimal  @db.Decimal(10, 2)
  startDate  DateTime @db.Date
  endDate    DateTime @db.Date
  daysOfWeek Int[]
  isActive   Boolean  @default(true)
  @@index([roomTypeId, startDate, endDate])
}

// ==================== AUDIT LOG ====================

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  action     String
  entityType String
  entityId   String
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  userAgent  String?
  timestamp  DateTime @default(now())
  @@index([entityType, entityId])
  @@index([userId, timestamp])
}

// ==================== ENUMS ====================

enum RoomStatus {
  VACANT_CLEAN
  VACANT_DIRTY
  OCCUPIED_CLEAN
  OCCUPIED_DIRTY
  OUT_OF_ORDER
  OUT_OF_SERVICE
}

enum ReservationStatus {
  TENTATIVE
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
  NO_SHOW
}

enum FolioType {
  GUEST
  MASTER
  COMPANY
}

enum TransactionType {
  CHARGE
  PAYMENT
  ADJUSTMENT
  TRANSFER
}

enum PaymentMethod {
  CASH
  CREDIT_CARD
  DEBIT_CARD
  BANK_TRANSFER
  QR_PAYMENT
  VIRTUAL_CARD
  DIRECT_BILL
  VOUCHER
}

enum ShiftStatus {
  OPEN
  CLOSED
  BALANCED
}

enum AuditStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum InvoiceStatus {
  OPEN
  PARTIAL
  PAID
  OVERDUE
  VOID
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}
